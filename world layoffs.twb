                <story-points>
                  <story-point caption='Layoffs peaked mid‑2023, signaling industry instability.' captured-sheet='-  Layoffs by Company &amp; Industry' id='1' />
                  <story-point caption='Layoffs accelerated sharply after 2020, peaking at over 127,000 in 2023' captured-sheet='Layoffs Over Time' id='7' />
                  <story-point caption='North America and Europe faced the sharpest cuts.' captured-sheet='- Geographic Impact' id='9' />
                  <story-point caption='Early‑stage startups proved more vulnerable to workforce reductions.' captured-sheet='- Stage vs Layoffs' id='10' />
                  <story-point caption='High funding didn’t always protect against layoffs.' captured-sheet='Funds Raised vs Layoffs' id='11' />
                  <story-point caption='A handful of firms accounted for the majority of cuts.' captured-sheet='Top 10 Companies by Layoffs' id='14' />
                  <story-point caption='Layoffs reshaped industries between 2020–2023, exposing resilience gaps across regions, funding stages, and company scale.' captured-sheet='Global Layoffs Trends 2023' id='15' />
